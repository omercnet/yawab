{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**",
      "*.{ts,tsx,json,jsonc}",
      "index.html",
      "!dist",
      "!coverage",
      "!node_modules",
      "!pnpm-lock.yaml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 90
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {},
      "complexity": {
        "noVoid": "off",
        "noExcessiveCognitiveComplexity": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUndeclaredDependencies": "off",
        "useImportExtensions": "off",
        "noNodejsModules": "off"
      },
      "performance": {},
      "security": {},
      "suspicious": {
        "noExplicitAny": "error",
        "noReactSpecificProps": "off"
      },
      "style": {
        "noDefaultExport": "off",
        "noNonNullAssertion": "off",
        "noImplicitBoolean": "off",
        "noParameterProperties": "off",
        "useBlockStatements": "off",
        "useNamingConvention": "off",
        "useSingleVarDeclarator": "off"
      }
    }
  },
  "javascript": {
    "globals": ["JSX"],
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "linter": {
        "rules": {
          "performance": { "useTopLevelRegex": "off" },
          "correctness": { "noEmptyPattern": "off" }
        }
      }
    }
  ]
}
