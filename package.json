{
  "name": "yawab",
  "version": "1.1.0",
  "description": "Cross-platform desktop app to send WhatsApp messages to a CSV contact list, paired over QR using Baileys.",
  "author": "yawab",
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "pnpm run typecheck && electron-vite build",
    "verify:bundle": "node scripts/verify-bundle.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:win": "pnpm run build && electron-builder --win",
    "build:linux": "pnpm run build && electron-builder --linux",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "biome lint .",
    "check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "screenshots:marketing": "GENERATE_SCREENSHOTS=1 xvfb-run -a playwright test e2e/marketing-screenshots.spec.ts"
  },
  "dependencies": {
    "@sentry/electron": "^7.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@whiskeysockets/baileys": "~6.7.23",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-updater": "^6.8.9",
    "electron-vite": "^5.0.0",
    "i18next": "^26.3.1",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "typescript": "^6.0.3",
    "uqr": "^0.1.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
